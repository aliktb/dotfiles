{
    "layer": "top",
    "position": "top",
    "height": 36,
    "modules-left": ["sway/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "temperature", "memory", "disk", "pulseaudio", "network", "backlight", "battery", "tray", "custom/lock"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}"
    },
    "clock": {
        "interval": 1,
        "format": "{:%d/%m/%Y %H:%M:%S}  ",
        "timezone": "Europe/London",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>"
    },
    "custom/music": {
        "format": "♪  {}",
        "escape": true,
        "interval": 5,
        "tooltip": false,
        "exec": "playerctl metadata --format='{{ artist }} — {{ title }}'",
        "on-click": "playerctl play-pause",
        "max-length": 60
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon}",
        "format-icons": ["", "", "", "", "", "", "", "", ""]
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "    {capacity}%",
        "format-plugged": "    {capacity}%",
        "format-icons": ""
    },
    "cpu": {
        "interval": 10,
        "format": "{usage}%  ",
        "max-length": 10
    },
    "temperature": {
        "thermal-zone": 10,
        "format": "{temperatureC}°C "
    },
    "memory": {
    "interval": 30,
    "format": "{avail}GiB  ",
    "max-length": 11,
    "tooltie": true,
    "tooltip-format": "{percentage}% used"
    },
    "disk": {
    "interval": 30,
    "format": "{free}  ",
    "path": "/"
    },
    "network": {
        "format-wifi": "",
        "format-ethernet": "",
        "format-linked": "",
        "format-disconnected": "⚠",
        "format-alt": "{ipaddr}/{cidr} - Signal Strength: {signalStrength}%"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}  {volume}%",
        "format-muted": "",
        "format-icons": {
            "default": ["", "", " "]
        }
    },
    "custom/lock": {
        "tooltip": false,
        "on-click": "wlogout --protocol layer-shell --buttons-per-row 5 --column-spacing 10 --row-spacing 10 --margin 400 --no-span",
        "format": ""
    },
    "tray": {
        "icon-size": 16,
        "spacing": 8
    }
}
